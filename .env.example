# Copy this file to .env and replace both secrets before starting MyProbe.
# Leave MYPROBE_IMAGE unset to build locally, or use the published GHCR image.
# MYPROBE_IMAGE=ghcr.io/zhengyifei200112-collab/myprobe:latest
MYPROBE_ADMIN_USERNAME=admin
MYPROBE_ADMIN_PASSWORD=replace-with-a-long-unique-password
MYPROBE_ENCRYPTION_KEY=replace-with-at-least-32-random-characters

# Direct-IP mode exposes http://SERVER_IP:25775. Use a strong unique password.
MYPROBE_BIND_ADDRESS=0.0.0.0
MYPROBE_PORT=25775
MYPROBE_COOKIE_SECURE=false
MYPROBE_TRUSTED_PROXIES=
MYPROBE_PUBLIC_HTTP_ACKNOWLEDGED=true

# For an HTTPS domain reverse proxy, use 127.0.0.1, enable secure cookies, and set the
# exact proxy address/CIDR seen by the container in MYPROBE_TRUSTED_PROXIES.
# Set MYPROBE_PUBLIC_HTTP_ACKNOWLEDGED=true only after HTTPS is active, or when direct
# HTTP exposure is deliberately accepted. It does not enable TLS.

MYPROBE_RAW_RETENTION_DAYS=7
MYPROBE_MINUTE_RETENTION_DAYS=30
MYPROBE_FIVE_MINUTE_RETENTION_DAYS=365
MYPROBE_RETENTION_INTERVAL_HOURS=1
