# Copy to a root-readable file such as /opt/myprobe-agent/agent.env.
# Pin a release tag in production so upgrades and rollbacks are deterministic.
MYPROBE_AGENT_IMAGE=ghcr.io/zhengyifei200112-collab/myprobe-agent:latest
MYPROBE_SERVER=https://status.example.com
MYPROBE_TOKEN=replace-with-the-one-time-node-token
